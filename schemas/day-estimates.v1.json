{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://day.dev/schemas/day-estimates.v1.json",
  "title": "day-estimates.v1",
  "type": "object",
  "required": [
    "schemaVersion",
    "label",
    "grossApyBps",
    "netApyBps",
    "feeBps",
    "stakedMicros",
    "liquidMicros",
    "netYieldMonthlyMicros",
    "netYieldDailyMicros"
  ],
  "properties": {
    "schemaVersion": { "const": "day-estimates.v1" },
    "label": { "type": "string" },
    "grossApyBps": { "type": ["number", "null"] },
    "netApyBps": { "type": ["number", "null"] },
    "feeBps": { "type": "integer" },
    "stakedMicros": { "type": "string" },
    "liquidMicros": { "type": "string" },
    "netYieldMonthlyMicros": { "type": ["string", "null"] },
    "netYieldDailyMicros": { "type": ["string", "null"] },
    "notes": { "type": "array", "items": { "type": "string" } }
  }
}
