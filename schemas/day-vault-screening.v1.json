{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dayprotocol.com/schemas/day-vault-screening.v1.json",
  "title": "day-vault-screening.v1",
  "description": "DAY-352 screening rubric result for vault candidates (pre-allowlist). Default deny for LIST membership.",
  "type": "object",
  "required": ["schemaVersion", "pass", "decision", "reasons", "criteria"],
  "properties": {
    "schemaVersion": { "const": "day-vault-screening.v1" },
    "pass": { "type": "boolean" },
    "decision": { "type": "string", "enum": ["pass", "fail"] },
    "reasons": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1
    },
    "criteria": {
      "type": "object",
      "required": ["minTvlUsd", "minAgeDays"],
      "properties": {
        "minTvlUsd": { "type": "number", "minimum": 0 },
        "minAgeDays": { "type": "number", "minimum": 0 },
        "requireFee": { "type": "boolean" },
        "requireCurator": { "type": "boolean" },
        "platforms": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
